extends ../layout/index 
block contenido 
    .py-10 
        h1.text-4xl.my-10.font-extrabold.text-center.text-purple-500 Bienes 
            span.font-normal.text-black Raices 
        h2.text-center.text-2xl.font-normal.text-black Por favor ingresa cuidadosamente tus datos:

        if errores 
            .max-w-md.mx-auto.my-10 
                each error in errores 
                    p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold= error.msg 

        .mt-8.mx-auto.max-w-xl
            .bg-white.py-8.px-4.shadow-2xl.rounded-2xl 
                form.space-y-5(method="POST" action="/auth/registro" noValidate)
                    input(type="hidden" name="_csrf" value=csrfToken)

                    div.px-5 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="nombreUsuario") Nombre completo: 
                        input#nombreUsuario(
                            type="text" 
                            class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-purple-300 focus:outline-none" 
                            placeholder="p.e.: Blanca Sarahi Melendez Torres" 
                            name="nombreUsuario" 
                            value= usuario ? usuario.nombreUsuario : ''
                        ).w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400
                    
                    div.px-5 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico: 
                        input#emailUsuario(
                            type="email" 
                            class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-purple-300 focus:outline-none" 
                            placeholder="p.e.: correo@ejemplo.com" 
                            name="emailUsuario" 
                            value= usuario ? usuario.emailUsuario : ''
                        ).w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400

                    div.px-5 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Contraseña: 
                        input#passwordUsuario(
                            type="password" 
                            class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-purple-300 focus:outline-none" 
                            placeholder="Por lo menos 8 caracteres" 
                            name="passwordUsuario"
                        ).w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400
                    
                    div.px-5 
                        label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="confirmacionUsuario") Confirmación de contraseña: 
                        input#confirmacionUsuario(
                            type="password" 
                            class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-purple-300 focus:outline-none" 
                            placeholder="Repite la contraseña anterior" 
                            name="confirmacionUsuario"
                        ).w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400

                    input(
                        type="submit" 
                        value="Registrar Usuario"
                        class="w-full bg-gray-300 text-purple-600 hover:bg-purple-600 hover:text-white font-bold py-3 cursor-pointer rounded-4xl shadow-lg uppercase transition-all duration-200"
                    )

                    div.flex.items-center.justify-between.pt-3 
                        a(
                            class="text-gray-500 text-sm hover:decoration-purple-400 hover:underline transition decoration-2" 
                            href="/auth/login"
                        ) ¿Ya tienes cuenta? Inicia Sesión 
                        a(
                            class="text-gray-500 text-sm hover:decoration-purple-400 hover:underline transition decoration-2" 
                            href="/auth/recuperarPassword"
                        ) ¿Olvidaste tu contraseña? Recupérala